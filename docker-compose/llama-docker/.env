# Какой файл модели использовать (должен лежать в папке ./models)
LLAMA_MODEL_FILE=qwen2.5-coder-7b-instruct-q4_k_m.gguf

# Порт, на котором будет доступен API
LLAMA_PORT=8080

# Размер контекста (токенов). Для кода лучше 8192 или 16384
LLAMA_CTX_SIZE=8192

# Количество слоёв, отправляемых на GPU (99 = всё, что можно)
LLAMA_N_GPU_LAYERS=99

# Параметры генерации
LLAMA_TEMP=0.2
LLAMA_TOP_K=40
LLAMA_TOP_P=0.95
LLAMA_REPEAT_PENALTY=1.1

# Количество потоков CPU (обычно = число ядер)
LLAMA_THREADS=8
LLAMA_BATCH_SIZE=512